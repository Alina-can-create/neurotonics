# Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Allowed CORS origins — comma-separated list of frontend URLs
# For GitHub Pages: https://elitedigitalconsulting.github.io
# For local dev:    http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000

# Port the server listens on (default: 4000)
PORT=4000

# ---------------------------------------------------------------------------
# Email — stockist application form
# Nodemailer sends stockist applications to the admin email via SMTP.
#
# Gmail example (recommended: use an App Password, not your account password):
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false          # false = STARTTLS on port 587; true = TLS on 465
#   EMAIL_USER=your-address@gmail.com
#   EMAIL_PASS=your-16-char-app-password
#
# Generic SMTP example:
#   EMAIL_HOST=mail.yourdomain.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=noreply@yourdomain.com
#   EMAIL_PASS=your-smtp-password
#
# Sending address (the From header in the email):
#   EMAIL_FROM=noreply@neurotonics.com.au
#
# Destination for stockist applications (must match your mail account):
#   STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password-or-app-password
EMAIL_FROM=noreply@neurotonics.com.au
STOCKIST_EMAIL=admin@elitedigitalconsulting.com.au
